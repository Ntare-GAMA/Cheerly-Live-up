# Server Configuration
PORT=3000
NODE_ENV=development

# Firebase Admin SDK
# Option 1: Service account file path
# FIREBASE_SERVICE_ACCOUNT_PATH=./path/to/serviceAccountKey.json

# Option 2: Individual credentials (use this OR the file path above)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# JWT Secret (change this to a random string in production)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Frontend base URL — must match where payment.html is opened (used for Stripe redirects)
FRONTEND_URL=http://localhost:3000

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
# Optional: Price IDs from Stripe Dashboard → Products (if omitted, server uses inline $9.99/mo price_data)
# STRIPE_PRICE_MONTHLY=price_xxxxxxxx
# STRIPE_PRICE_YEARLY=price_xxxxxxxx

